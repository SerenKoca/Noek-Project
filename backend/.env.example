# Backend environment variables for Noek room storage
MONGO_URI=mongodb://127.0.0.1:27017/noek
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_REGISTRATION_CODE=replace_with_private_admin_registration_code
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace_with_strong_password
ADMIN_SEED_DISPLAY_NAME=Super Admin
# Optional: zet op true om bestaand admin wachtwoord te resetten tijdens seed
ADMIN_SEED_RESET_PASSWORD=false
PORT=5000
