{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/admin/funeral-directors/:path*",
      "destination": "/api/admin/funeral-directors?path=:path*"
    },
    {
      "source": "/api/poly-api",
      "destination": "/api/poly-api-handler"
    },
    {
      "source": "/api/poly-api/:path*",
      "destination": "/api/poly-api-handler?path=:path*"
    },
    {
      "source": "/api/poly-static",
      "destination": "/api/poly-static-handler"
    },
    {
      "source": "/api/poly-static/:path*",
      "destination": "/api/poly-static-handler?path=:path*"
    },
    {
      "source": "/api/rooms",
      "destination": "/api/rooms-handler"
    },
    {
      "source": "/api/rooms/:path*",
      "destination": "/api/rooms-handler?path=:path*"
    },
    {
      "source": "/api/public/:path*",
      "destination": "/api/public-handler?path=:path*"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
