# Poly Pizza API key (see provided OpenAPI spec: header name is x-auth-token)
VITE_POLYPIZZA_API_KEY= #optional
POLYPIZZA_API_KEY=

# Noek rooms API on Vercel uses the built-in /api routes
# No extra backend URL is needed

# MongoDB connection string for the rooms API on Vercel
MONGO_URI=

# Optional: override the base URLs if you host your own proxy endpoints
# VITE_POLYPIZZA_API_BASE_URL=https://your-proxy.example.com/v1.1
# VITE_POLYPIZZA_STATIC_BASE_URL=https://your-proxy.example.com/static
