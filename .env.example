# Poly Pizza API key (see provided OpenAPI spec: header name is x-auth-token)
VITE_POLYPIZZA_API_KEY= #optional
POLYPIZZA_API_KEY=

# Noek rooms API on Vercel uses the built-in /api routes
# No extra backend URL is needed

# MongoDB connection string for the rooms API on Vercel
MONGO_URI=

# JWT signing secret for account login/register
# Use a long random value in production
JWT_SECRET=

# Registration code needed to self-register an admin account through /api/auth
ADMIN_REGISTRATION_CODE=

# Optional: override the base URLs if you host your own proxy endpoints
# VITE_POLYPIZZA_API_BASE_URL=https://your-proxy.example.com/v1.1
# VITE_POLYPIZZA_STATIC_BASE_URL=https://your-proxy.example.com/static

# Optional: pin furniture from your own Poly Pizza list (full URL or list ID)
# Example: VITE_POLYPIZZA_FURNITURE_LIST=https://poly.pizza/l/ILAPXeUYiS
VITE_POLYPIZZA_FURNITURE_LIST=

# Optional: multiple furniture lists (comma/semicolon/newline separated URLs or IDs)
# Example: VITE_POLYPIZZA_FURNITURE_LISTS=https://poly.pizza/bundle/Furniture-Kit-NoG1sEUD1z,ILAPXeUYiS
VITE_POLYPIZZA_FURNITURE_LISTS=

# Optional: pin individual model links/IDs (comma/semicolon/newline separated)
# Example: VITE_POLYPIZZA_PINNED_MODELS=https://poly.pizza/m/ZOPP3KzNIk,myd1WSucAz
VITE_POLYPIZZA_PINNED_MODELS=

# Optional: exclude model IDs (comma/semicolon/newline separated)
VITE_POLYPIZZA_EXCLUDE_IDS=

# Optional: exclude by text keywords in title/category/tags
# Example: VITE_POLYPIZZA_EXCLUDE_KEYWORDS=car,truck,vehicle
VITE_POLYPIZZA_EXCLUDE_KEYWORDS=

# Optional: set to true to show ONLY models from configured lists/pinned models
VITE_POLYPIZZA_ONLY_CONFIGURED=false

# Cloudinary unsigned upload settings for file uploads
# Use the cloud name from your Cloudinary dashboard
VITE_CLOUDINARY_CLOUD_NAME= 

# Unsigned upload preset that allows direct browser uploads
VITE_CLOUDINARY_UPLOAD_PRESET=
